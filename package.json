{
  "name": "praxis",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=24.7.0"
  },
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev:backend": "tsx watch backend/src/server.ts",
    "dev:frontend": "vite",
    "dev": "concurrently -n \"API,WEB\" -c \"magenta,cyan\" \"pnpm run dev:backend\" \"pnpm run dev:frontend\"",
    "build:frontend": "vite build",
    "build:backend": "tsc",
    "build": "pnpm build:frontend && pnpm build:backend",
    "start": "node backend/dist/server.js",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:all": "pnpm typecheck && pnpm test",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx backend/scripts/migrate.ts",
    "db:migrate:name-initials": "tsx backend/scripts/migrate-name-initials.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@hono/node-server": "^2.0.4",
    "@hono/zod-validator": "^0.8.0",
    "@radix-ui/react-alert-dialog": "^1.1.16",
    "@radix-ui/react-checkbox": "^1.3.4",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-label": "^2.1.9",
    "@radix-ui/react-scroll-area": "^1.2.11",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-separator": "^1.1.9",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@tanstack/react-table": "^8.21.3",
    "busboy": "^1.6.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "drizzle-orm": "1.0.0-beta.22",
    "echarts": "^6.1.0",
    "fast-csv": "^5.0.7",
    "hono": "^4.12.25",
    "jose": "^6.2.3",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "pinyin-pro": "^3.28.1",
    "pqseal": "^1.0.0",
    "radix-ui": "^1.5.0",
    "react": "^19.2.7",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.17.0",
    "shadcn": "^4.11.0",
    "sharp": "^0.35.1",
    "smol-toml": "^1.6.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/busboy": "^1.5.4",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "drizzle-kit": "1.0.0-beta.22",
    "happy-dom": "^20.10.3",
    "tailwindcss": "^4.3.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
