{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "frontend/src/*"
      ]
    },
    "lib": [
      "ES2022",
      "DOM"
    ],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "resolveJsonModule": true,
    "types": [
      "bun"
    ],
    "isolatedModules": true
  },
  "include": [
    "backend/src/**/*.ts",
    "backend/src/**/*.d.ts",
    "backend/tests/**/*.ts",
    "frontend/src/**/*.ts",
    "frontend/src/**/*.tsx",
    "frontend/vite.config.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "frontend/dist",
    "frontend-legacy",
    "node_modules"
  ]
}
